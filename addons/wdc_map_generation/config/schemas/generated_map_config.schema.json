{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WDC Generated Map Config",
  "type": "object",
  "required": ["schema_version", "id", "display_name", "map", "terrain", "minerals", "poi_generation"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "map": {
      "type": "object",
      "required": ["width_cells", "height_cells", "seed"],
      "properties": {
        "width_cells": { "type": "integer", "minimum": 8 },
        "height_cells": { "type": "integer", "minimum": 8 },
        "cell_size_m": { "type": "number", "exclusiveMinimum": 0 },
        "seed": {
          "type": "object",
          "properties": {
            "mode": { "enum": ["random", "fixed"] },
            "fixed_value": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "map_layers": {
      "type": "array",
      "description": "Three concentric map layers resolved from the map geometry center.",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "enum": ["inner", "middle", "outer"] },
          "max_radius_cells": { "type": "number", "minimum": 0 },
          "max_radius_ratio": { "type": "number", "minimum": 0 },
          "stone_max_hit_points": { "type": "integer", "minimum": 1 },
          "mineral_budget_weight": { "type": "number", "minimum": 0 },
          "poi_budget_weight": { "type": "number", "minimum": 0 },
          "trap_budget_weight": { "type": "number", "minimum": 0 },
          "monster_budget_weight": { "type": "number", "minimum": 0 },
          "room_content_danger_multiplier": { "type": "number", "minimum": 0 }
        },
        "anyOf": [
          { "required": ["max_radius_cells"] },
          { "required": ["max_radius_ratio"] }
        ]
      }
    },
    "terrain": { "type": "object" },
    "minerals": { "type": "object" },
    "poi_generation": { "type": "object" },
    "monster_generation": { "type": "object" },
    "debug": { "type": "object" }
  }
}
