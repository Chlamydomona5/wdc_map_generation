{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WDC Generated Map Config",
  "type": "object",
  "required": ["schema_version", "id", "display_name", "map", "terrain", "minerals", "poi_generation"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "map": {
      "type": "object",
      "required": ["width_cells", "height_cells", "seed"],
      "properties": {
        "width_cells": { "type": "integer", "minimum": 8 },
        "height_cells": { "type": "integer", "minimum": 8 },
        "cell_size_m": { "type": "number", "exclusiveMinimum": 0 },
        "seed": {
          "type": "object",
          "properties": {
            "mode": { "enum": ["random", "fixed"] },
            "fixed_value": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "terrain": { "type": "object" },
    "minerals": { "type": "object" },
    "poi_generation": { "type": "object" },
    "monster_generation": { "type": "object" },
    "debug": { "type": "object" }
  }
}

